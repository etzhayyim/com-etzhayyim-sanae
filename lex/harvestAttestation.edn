[{:db/id -1, :lex.harvestAttestation/lexicon 1, :lex.harvestAttestation/id "com.etzhayyim.sanae.harvestAttestation", :lex.harvestAttestation/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"parcelId\" \"varietal\" \"yieldKg\" \"createdAt\"], :properties {:parcelId {:type \"string\", :description \"field parcel DID\"}, :varietal {:type \"string\", :description \"open-seed-bank varietal id (G9/N5 — no patented line)\"}, :yieldKg {:type \"integer\", :minimum 0, :description \"honest yield in kg (G8 — no inflation/shrinkage-hiding)\"}, :moisturePermille {:type \"integer\", :description \"grain moisture ×1000\"}, :robotSigs {:type \"array\", :items {:type \"string\"}, :description \"G3: >=2 robot Ed25519 sigs\"}, :humanAttestation {:type \"string\", :description \"G3: agronomist DID\"}, :photoCid {:type \"string\", :description \"IPFS CID of harvest photo evidence\"}, :createdAt {:type \"string\", :format \"datetime\"}}}}}"}]