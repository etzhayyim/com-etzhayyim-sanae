{:lexicon 1
 :id "com.etzhayyim.sanae.weedingPassRecord"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["parcelId" "method" "herbicideFree" "weedsCleared" "createdAt"]
    :properties
    {:parcelId {:type "string" :description "field parcel DID"}
     :rowsScanned {:type "integer" :minimum 0 :description "crop rows scanned by kusanagi this pass"}
     :weedsDetected {:type "integer" :minimum 0}
     :weedsCleared {:type "integer" :minimum 0}
     :method {:type "string" :enum ["mechanical" "laser"] :description "G9: herbicide is NOT a valid method"}
     :herbicideFree {:type "boolean" :const true :description "G9 invariant — always true"}
     :witnessQuorumMet {:type "boolean" :description "G3: >=2 robot sigs + >=1 human agronomist"}
     :createdAt {:type "string" :format "datetime"}}}}}}
