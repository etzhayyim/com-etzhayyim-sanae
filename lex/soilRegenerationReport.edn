{:lexicon 1
 :id "com.etzhayyim.sanae.soilRegenerationReport"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["parcelId" "soilCarbonDeltaPermille" "createdAt"]
    :properties
    {:parcelId {:type "string"}
     :soilCarbonDeltaPermille {:type "integer" :description "net change in soil-carbon ×1000 over the season; G9 requires >=0"}
     :microbialDiversityIndex {:type "integer" :description "Shannon index ×1000"}
     :netRegenerative {:type "boolean" :description "G9: soilCarbonDeltaPermille >= 0"}
     :waterUseLitersPerKg {:type "integer" :description "irrigation water per kg dry-matter (mitsuho G5 coupling)"}
     :createdAt {:type "string" :format "datetime"}}}}}}
