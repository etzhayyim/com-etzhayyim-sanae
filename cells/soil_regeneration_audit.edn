{:cell/id "soil_regeneration_audit"
 :cell/glyph "田螺"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "levi"
 :cell/doc "Annual soil-carbon + microbial-diversity assay (tanishi). Net soil-carbon must be >=0 (G9). Cross-cut verification cell."
